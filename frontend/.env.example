# =========================
# FRONTEND ENVIRONMENT CONFIGURATION
# =========================
# Copy this file to .env and fill in your actual values
# Safe to expose: Only anon/public Supabase keys should be here
# NEVER put service keys or JWT secrets in frontend

# =========================
# SUPABASE CONFIGURATION (FRONTEND - SAFE)
# =========================
# Use ANON key (publicly safe), NOT the service role key
# Get credentials from https://supabase.com/dashboard
# Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Storage bucket name (for file downloads)
VITE_SUPABASE_STORAGE_BUCKET=cipher-files

# =========================
# BACKEND API CONFIGURATION
# =========================
# Backend API endpoint
# Development: http://localhost:8000/api/v1
# Production: https://api.ciphersend.com/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# =========================
# APPLICATION CONFIGURATION
# =========================
# App name and version
VITE_APP_NAME=CipherSend
VITE_APP_VERSION=1.0.0

# File upload settings (frontend validation)
VITE_MAX_FILE_SIZE_MB=100

# Feature flags
VITE_ENABLE_ANALYTICS=false
VITE_ENVIRONMENT=development
